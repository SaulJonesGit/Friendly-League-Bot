{
  "name": "friendly-league-bot",
  "private": true,
  "version": "1.0.0",
  "description": "Friendly League Bot",
  "main": "dist/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/app.js",
    "register": "npm run build && node dist/commands.js",
    "dev": "tsx watch app.ts",
    "typecheck": "tsc --noEmit",
    "generate-ids": "tsx scripts/runGenerateIDs.ts"
  },
  "author": "Saul Jones",
  "license": "MIT",
  "dependencies": {
    "discord-interactions": "^4.0.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "axios": "latest"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest":"30.3.0",
    "typescript": "^5.8.2",
    "tsx": "^4.20.3",
    "@types/node": "^22.14.1",
    "@types/express": "^5.0.1"
  }
}